FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

muValG 1.61E-5;
rhoValG 50.0;
nuValG #calc "$muValG / $rhoValG";
muValL 0.001;
rhoValL 1000.0;
nuValL #calc "$muValL / $rhoValL";

phases          (water air);

water
{
    transportModel  Newtonian;
    nu              $nuValL;
    rho             $rhoValL;
}

air
{
    transportModel  Newtonian;
    nu              $nuValG;
    rho             $rhoValG;
}

sigma           0.07;


