       RowBox[{
        RowBox[{"Cos", "[", "\[Delta]f", "]"}], 
        RowBox[{"Sinh", "[", 
         RowBox[{"omega", "  ", "\[Delta]f"}], "]"}]}]}], ")"}]}], 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"Sinh", "[", 
        RowBox[{"omega", " ", "\[Pi]"}], "]"}], ")"}], "2"], " ", 
     RowBox[{"(", 
      RowBox[{"Cosh", "[", 
       RowBox[{"omega", " ", "\[Delta]f"}], "]"}], ")"}]}]]}], 
  ";"}]}], "Input",
