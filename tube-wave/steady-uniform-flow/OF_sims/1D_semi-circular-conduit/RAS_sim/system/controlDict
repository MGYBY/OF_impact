FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// application     incompressibleVoF;
// application     interIsoCyclicFoam;
solver          incompressibleVoF;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         12.50;

deltaT          0.0001;

writeControl    adjustableRunTime;

writeInterval   0.50;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression uncompressed;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

adjustTimeStep  on;

maxCo           0.40;
maxAlphaCo      0.40;

maxDeltaT       0.05;

// DebugSwitches
// {
//     MULES           1;
// }

functions
{
    alphaWaterU
    {
        type            multiply;
        libs            ("libfieldFunctionObjects.so");

        fields          (alpha.water U);
        result          alphaWaterU;

        executeControl  timeStep;
        executeInterval 1;

        writeControl    none;
    }

    alphaAirU
    {
        type            multiply;
        libs            ("libfieldFunctionObjects.so");

        fields          (alpha.air U);
        result          alphaAirU;

        executeControl  timeStep;
        executeInterval 1;

        writeControl    none;
    }

    waterFlux_x0025
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");

        log             false;
        writeFields     false;

        writeControl    timeStep;
        writeInterval   25;

        regionType      sampledSurface;
        sampledSurface
        {
            type            cutPlane;
            planeType       pointAndNormal;
            point           (0.025 0 0);
            normal          (1 0 0);
            interpolate     yes;
        }

        operation       areaNormalIntegrate;
        fields          (alphaWaterU);
    }

    airFlux_x0025
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");

        log             false;
        writeFields     false;

        writeControl    timeStep;
        writeInterval   25;

        regionType      sampledSurface;
        sampledSurface
        {
            type            cutPlane;
            planeType       pointAndNormal;
            point           (0.025 0 0);
            normal          (1 0 0);
            interpolate     yes;
        }

        operation       areaNormalIntegrate;
        fields          (alphaAirU);
    }
}
