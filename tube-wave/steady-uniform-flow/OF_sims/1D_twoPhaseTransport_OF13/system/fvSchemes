FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         Euler;
}

gradSchemes
{
    default         Gauss linear;
    limited         cellLimited Gauss linear 1;
    // default         leastSquares;
}

divSchemes
{
    default             none;
    // default             Gauss linear
    
    // div(rhoPhi,U)   Gauss linearUpwind grad(U);
    // div(phi,alpha)  Gauss vanLeer;
    // div(phirb,alpha) Gauss linear;
    // div(phi,k)      Gauss Minmod;
    // div(phi,epsilon) Gauss Minmod;
    // div(((rho*nuEff)*dev2(T(grad(U))))) Gauss linear;

    // div(rhoPhi,U)       Gauss linearUpwindV grad(U);
    // div(phi,alpha)      Gauss vanLeer;
    // div(phi,alpha)  Gauss interfaceCompression vanLeer 1;
    div(phi,alpha)  Gauss PLIC interfaceCompression vanLeer 1;
    div(rhoPhi,U)   Gauss cellCoBlended 2 linearUpwind grad(U) 5 upwind;
    div(phirb,alpha)    Gauss linear;

    "div\(phi,(k|omega)\)"      Gauss upwind;
    // "div\(phi,(k|omega)\)"      Gauss linearUpwind limitedGrad;
    div(((rho*nuEff)*dev2(T(grad(U))))) Gauss linear;

    div(phi,s)   Gauss vanLeer;
    div(phirb,s) Gauss linear;

    // div(alphaPhi.air,omega.air) Gauss limitedLinearV 1;
    // div(alphaPhi.air,k.air) Gauss limitedLinearV 1;
    div(alphaPhi.air,omega.air) Gauss upwind;
    div(alphaPhi.air,k.air) Gauss upwind;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

wallDist
{
    method          meshWave;
}


