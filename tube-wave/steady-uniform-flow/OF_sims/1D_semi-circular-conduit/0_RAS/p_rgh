FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    Front
    {
        type            prghCyclicPressure;
        patchType       cyclic;
        rhoInf          1.225;
    }

    Back
    {
        type            prghCyclicPressure;
        patchType       cyclic;
    }

    Symmetry
    {
        type            symmetryPlane;
    }
    
    ".*"
    {
        type            fixedFluxPressure;
        value           uniform 0;
    }
}


