FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// application     incompressibleVoF;
application     interIsoCyclicFoam;
// solver          incompressibleVoF;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         16.50;

deltaT          0.0001;

writeControl    adjustableRunTime;

writeInterval   0.50;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

adjustTimeStep  on;

maxCo           0.4750;
maxAlphaCo      0.4750;

maxDeltaT       0.05;

// DebugSwitches
// {
//     MULES           1;
// }

functions
{
    waterFluxVec
    {
        type            exprField;
        libs            (fieldFunctionObjects);

        field           waterFluxVec;
        expression      "alpha.water*U";
        dimensions      [0 1 -1 0 0 0 0];

        writeControl    none;
    }

    airFluxVec
    {
        type            exprField;
        libs            (fieldFunctionObjects);

        field           airFluxVec;
        expression      "(1 - alpha.water)*U";
        dimensions      [0 1 -1 0 0 0 0];

        writeControl    none;
    }

    waterFlux_x0025
    {
        type            surfaceFieldValue;
        libs            (fieldFunctionObjects);

        writeControl    timeStep;
        writeInterval   25;

        log             false;
        writeFields     false;
        surfaceFormat   none;

        regionType      sampledSurface;
        name            x0025Plane;

        sampledSurfaceDict
        {
            type            cuttingPlane;
            planeType       pointAndNormal;
            pointAndNormalDict
            {
                point       (0.025 0 0);
                normal      (1 0 0);
            }
            interpolate     true;
        }

        operation       areaNormalIntegrate;
        fields
        (
            waterFluxVec
        );
    }

    airFlux_x0025
    {
        type            surfaceFieldValue;
        libs            (fieldFunctionObjects);

        writeControl    timeStep;
        writeInterval   25;

        log             false;
        writeFields     false;
        surfaceFormat   none;

        regionType      sampledSurface;
        name            x0025Plane;

        sampledSurfaceDict
        {
            type            cuttingPlane;
            planeType       pointAndNormal;
            pointAndNormalDict
            {
                point       (0.025 0 0);
                normal      (1 0 0);
            }
            interpolate     true;
        }

        operation       areaNormalIntegrate;
        fields
        (
            airFluxVec
        );
    }
}
