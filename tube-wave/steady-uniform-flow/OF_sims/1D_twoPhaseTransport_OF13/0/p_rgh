FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inflow
    {
        type            prghCyclicPressure;
        patchType       cyclic;
        rhoInf          1.225;
    }
    rightWall
    {
        type            prghCyclicPressure;
        patchType       cyclic;
    }
    lowerWall
    {
        type            fixedFluxPressure;
        gradient        uniform 0;
        value           uniform 0;
    }
    atmosphere
    {
        // type            totalPressure;
        // rho             rho;
        // psi             none;
        // gamma           1;
        // p0              uniform 0;
        // value           uniform 0;

        type            prghTotalPressure;
        p0              $internalField;
    }
    frontAndBack
    {
        type            empty;
    }
}


