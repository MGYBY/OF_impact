Notebook[{

Cell[CellGroupData[{
Cell["Biberg (1999) analytical solution", "Section",
 CellChangeTimes->{{3.9826754519467826`*^9, 3.9826754608010426`*^9}, {
  3.982684422071534*^9, 
  3.9826844227156763`*^9}},ExpressionUUID->"bc6a65d5-5b17-4bc0-8c77-\
a8706c893421"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"F", "[", "\[Delta]f_", "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     FractionBox[
      RowBox[{"\[Omega]", " ", 
       RowBox[{"Tanh", "[", 
        RowBox[{"\[Omega]", "  ", "\[Delta]f"}], "]"}]}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"Sinh", "[", 
         RowBox[{"\[Pi]", " ", "\[Omega]"}], "]"}], ")"}], "2"]], ",", 
     RowBox[{"{", 
      RowBox[{"\[Omega]", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"phi", "[", "\[Delta]f_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "\[Pi]"], 
     RowBox[{"(", 
      RowBox[{"\[Delta]f", "-", 
       RowBox[{"Sin", "[", 
        RowBox[{"2", " ", "\[Delta]f"}], "]"}], "+", 
       RowBox[{
        FractionBox["1", "4"], 
        RowBox[{"Sin", "[", 
         RowBox[{"4", " ", "\[Delta]f"}], "]"}]}]}], ")"}]}], "+", 
    RowBox[{"2", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"Sin", "[", 
        RowBox[{"2", " ", "\[Delta]f"}], "]"}], ")"}], "2"], 
     RowBox[{"F", "[", "\[Delta]f", "]"}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.982667054321191*^9, 3.9826672120905914`*^9}, {
  3.9826675977829437`*^9, 3.982667841009138*^9}, {3.982667922285841*^9, 
  3.982668195095211*^9}, {3.9826722626074553`*^9, 3.9826722952745657`*^9}, {
  3.9826723913416452`*^9, 3.982672431030198*^9}, {3.982672829584898*^9, 
  3.9826728742896476`*^9}, {3.982672906987184*^9, 3.9826729653888454`*^9}, {
  3.982684485310851*^9, 3.982684684714111*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"4661190f-4617-4b25-a29f-0984623d5dff"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Q1fForm", "[", 
   RowBox[{
   "r_", ",", "\[Eta]f_", ",", "\[Rho]f_", ",", " ", "So_", ",", "gp_", ",", 
    "\[Delta]f_"}], "]"}], ":=", 
  RowBox[{
   FractionBox[
    RowBox[{"\[Rho]f", " ", "gp", " ", "So", " ", "\[Pi]", " ", 
     SuperscriptBox["r", "4"]}], 
    RowBox[{"8", " ", "\[Eta]f"}]], 
   RowBox[{"(", 
    RowBox[{"phi", "[", "\[Delta]f", "]"}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.982673423597464*^9, 3.982673457284273*^9}, {
  3.9826735026381035`*^9, 3.982673531680896*^9}, {3.982673566025809*^9, 
  3.9826736543413534`*^9}, {3.9826736960764685`*^9, 3.982673861565157*^9}, {
  3.9826741058217382`*^9, 3.982674108748554*^9}, {3.982684729062706*^9, 
  3.9826848200296*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"9690e79b-5a82-44e0-8393-1eebf89ed09a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"epsilonf", "[", "\[Delta]f_", "]"}], ":=", 
   RowBox[{
    FractionBox["1", "\[Pi]"], 
    RowBox[{"(", 
     RowBox[{"\[Delta]f", "-", 
      RowBox[{
       FractionBox["1", "2"], 
       RowBox[{"Sin", "[", 
        RowBox[{"2", " ", "\[Delta]f"}], "]"}]}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"areaf", "[", 
    RowBox[{"\[Delta]f_", ",", "r_"}], "]"}], ":=", 
   RowBox[{
    FractionBox["1", "\[Pi]"], 
    RowBox[{"(", 
     RowBox[{"\[Delta]f", "-", 
      RowBox[{
       FractionBox["1", "2"], 
       RowBox[{"Sin", "[", 
        RowBox[{"2", " ", "\[Delta]f"}], "]"}]}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{"\[Pi]", " ", 
      SuperscriptBox["r", "2"]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Frf", "[", 
    RowBox[{
    "r_", ",", "\[Eta]f_", ",", "\[Rho]f_", ",", " ", "So_", ",", "gp_", ",", 
     "\[Delta]f_"}], "]"}], ":=", 
   FractionBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Q1fForm", "[", 
       RowBox[{
       "r", ",", "\[Eta]f", ",", "\[Rho]f", ",", " ", "So", ",", "gp", ",", 
        "\[Delta]f"}], "]"}], "/", 
      RowBox[{"areaf", "[", 
       RowBox[{"\[Delta]f", ",", "r"}], "]"}]}], ")"}], 
    SqrtBox[
     RowBox[{"gp", " ", "r", " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"Cos", "[", "\[Delta]f", "]"}]}], ")"}]}]]]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.982675411102664*^9, 3.982675419941353*^9}, 
   3.9826848283089786`*^9, 3.982684888383094*^9},
 CellLabel->"In[11]:=",ExpressionUUID->"ab7994a3-7130-476f-8bb0-0b269599265b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Compatibility Condition", "Section",
 CellChangeTimes->{{3.9826860266190944`*^9, 3.982686042602167*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"cb9a7c3d-0707-4687-a839-9594ebc6d734"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"compEqn", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"ul", " "}], "\[Pi]"], 
     RowBox[{"(", 
      RowBox[{"\[Delta]l", "-", 
       RowBox[{
        FractionBox["1", "2"], 
        RowBox[{"Sin", "[", 
         RowBox[{"2", "\[Delta]l"}], "]"}]}]}], ")"}], "\[Pi]", " ", 
     SuperscriptBox["r", "2"]}], " ", "==", " ", 
    RowBox[{
     FractionBox[
      RowBox[{"\[Rho]l", " ", "gp", " ", "So", " ", "\[Pi]", " ", 
       SuperscriptBox["r", "4"]}], 
      RowBox[{"8", " ", "\[Eta]l"}]], "PHIB"}]}], "//", 
   "Simplify"}]}]], "Input",
 CellChangeTimes->{{3.982686051185852*^9, 3.98268614818561*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"9f1d65a6-f016-4b8f-9f78-39e9306b4397"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{"gp", " ", "PHIB", " ", "\[Pi]", " ", 
     SuperscriptBox["r", "3"], " ", "So", " ", "\[Rho]l"}], "\[Eta]l"], "+", 
   RowBox[{"8", " ", "r", " ", "ul", " ", 
    RowBox[{"Cos", "[", "\[Delta]l", "]"}], " ", 
    RowBox[{"Sin", "[", "\[Delta]l", "]"}]}]}], "\[Equal]", 
  RowBox[{"8", " ", "r", " ", "ul", " ", "\[Delta]l"}]}]], "Output",
 CellChangeTimes->{3.982686148536807*^9},
 CellLabel->"Out[20]=",ExpressionUUID->"a1e1ac3c-0755-4455-afdb-b075bb205406"]
}, Open  ]],

Cell[BoxData[
 RowBox[{"Final", " ", 
  RowBox[{"form", ":", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Delta]", "l"], "-", 
       RowBox[{
        FractionBox["1", "2"], 
        RowBox[{"Sin", "[", 
         RowBox[{"2", " ", 
          SubscriptBox["\[Delta]", "l"]}], "]"}]}]}], ")"}], " ", 
     RowBox[{"(", 
      FractionBox["1", 
       SubscriptBox["Re", "l"]], ")"}]}], "==", 
    RowBox[{
     RowBox[{"(", 
      FractionBox["\[Pi]", 
       RowBox[{"8", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"Cos", "[", 
            SubscriptBox["\[Delta]", "l"], "]"}]}], ")"}], "2"]}]], ")"}], 
     "So", 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox["1", 
        SubscriptBox["Fr", "l"]], ")"}], "2"], 
     SubscriptBox["\[Phi]", "B"]}]}]}]}]], "Text",
 CellChangeTimes->{{3.9826866010726423`*^9, 
  3.982686733614544*^9}},ExpressionUUID->"76f21f42-246e-4159-9486-\
6a260a9cd2e4"]
}, Open  ]],

